# -----------------------------
# Frontend runtime (Vite)
# -----------------------------
VITE_APP_NAME=RiverX App
VITE_API_BASE_URL=/api

# -----------------------------
# Dev supervisor / preview runtime
# scripts/dev-supervisor.js
# -----------------------------
# App server mode (preferred). true=dev, false=preview.
VITE_DEV=true
# Backward-compatible legacy flag read by dev-supervisor.
NEXT_DEV=true

# Port used by vite dev/preview and supervisor warmup target.
PORT=8080
# Warmup URL path checked by supervisor after boot.
HEALTHCHECK_PATH=/

# Git sync behavior
GIT_BOOTSTRAP=false
GIT_POLL=true
GIT_POLL_INTERVAL=2000
PREVIEW_BRANCH=main
# Optional remote used for bootstrap/poll and error-reporter repo tag.
REPO_URL=

# -----------------------------
# Optional DB migration runtime
# scripts/db-init.js
# -----------------------------
# Required only when running db-init.
DATABASE_URL=
# Retry base delay (ms) for transient DB migration failures.
DB_MIGRATE_RETRY_MS=3000
# DB connection timeout (seconds) for migration command.
DB_MIGRATE_CONNECT_TIMEOUT_SEC=10
# Legacy/alternate connection timeout fallback used by db-init.
PGCONNECT_TIMEOUT=10
# Set true only if your DB provider requires SSL.
DATABASE_SSL=false
